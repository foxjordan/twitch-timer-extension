PORT=8080

# Twitch app (for EventSub)
TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret
BROADCASTER_USER_ID=12345678
BROADCASTER_USER_TOKEN=oauth_token_with_required_scopes

# Extension
EXTENSION_CLIENT_ID=your_extension_client_id
EXTENSION_SECRET=base64_encoded_extension_secret   # From Extensions console
EXTENSION_VERSION=0.0.1                            # Must match version in Dev Console

# Optional: CORS origin for local panel
PANEL_ORIGIN=http://localhost:5173

# Optional: simple token for overlay access
# If set, overlay endpoints require `?key=...` to match.
OVERLAY_KEY=change_me_for_overlay

# OAuth + session for configurator
# If not set, configurator will still prompt for Twitch login but fail to fetch tokens.
SESSION_SECRET=replace_me_with_random_string
# Optional explicit base URL for OAuth redirect; otherwise derived from request host
# SERVER_BASE_URL=http://localhost:8080

# Super-admin dashboard: comma-separated Twitch user IDs allowed to access /admin
SUPER_ADMIN_IDS=

# Postgres (Supabase pooler URL, port 6543 / transaction mode)
# Project Settings → Database → Connection string → "Transaction" tab
DATABASE_URL=postgresql://postgres.your-ref:password@aws-X-region.pooler.supabase.com:6543/postgres

# Cloudflare R2 — for sound files / TTS audio
R2_ACCOUNT_ID=your_account_id
R2_BUCKET=your_bucket_name
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key

# New Relic (optional)
NEW_RELIC_KEY=your_new_relic_key
NEW_RELIC_APP_NAME=twitch_timer_extension
